{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "avoid",
  "ignorePatterns": ["/pnpm-lock.yaml"],
  "singleQuote": true,
  "sortImports": {},
  "sortTailwindcss": {
    "functions": ["clsx", "cn", "cva", "twMerge"]
  },
  "overrides": [
    {
      "files": ["./packages/react/**"],
      "options": {
        "sortTailwindcss": {
          "stylesheet": "./packages/react/src/index.css"
        }
      }
    }
  ],
  "trailingComma": "none"
}
